{
  "name": "dzuls-dev-studio-api",
  "version": "1.0.0",
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --target=bun --outfile=dist/index.js",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc",
    "docs:check": "typedoc --treatWarningsAsErrors",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@elysia/cors": "^1.4.2",
    "@elysia/jwt": "^1.4.2",
    "@elysia/openapi": "^1.4.15",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "postgres": "^3.4.9",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@electric-sql/pglite": "^0.5.2",
    "@elysiajs/eden": "^1.4.9",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.100.0"
  }
}
